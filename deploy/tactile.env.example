# Network bind for Raspberry Pi host
TACTILE_HOST=0.0.0.0
TACTILE_PORT=5000
TACTILE_DEBUG=0
TACTILE_USE_RELOADER=0

# USB serial port to the board/Pico
# Check with: ls /dev/serial/by-id/
PICO_SERIAL_PORT=/dev/ttyACM0
PICO_SERIAL_STARTUP_SEC=3.0

# Optional debug logging for serial traffic
SERIAL_DEBUG=0

# Optional: set this on the Pi to forward board commands to a bridge service.
# Example: http://192.168.50.2:5050
# BOARD_BRIDGE_URL=
# BOARD_BRIDGE_TIMEOUT_SEC=5.0
